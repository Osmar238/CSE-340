<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>
    <form action="/new-organization" method="POST">
        <div class="form-group">
            <label for="name">Organization Name</label>
            <!-- Se agregó required y maxlength="150". NO pusimos minlength a propósito -->
            <input
                type="text"
                id="name"
                name="name"
                required
                maxlength="150"
            />
        </div>
        
        <div class="form-group">
            <label for="description">Description</label>
            <!-- Se agregó required y maxlength="500" -->
            <textarea
                id="description"
                name="description"
                required
                maxlength="500"
            ></textarea>
        </div>
        
        <div class="form-group">
            <label for="contactEmail">Contact Email</label>
            <!-- Se cambió type a "email" y se agregó required -->
            <input
                type="email"
                id="contactEmail"
                name="contactEmail"
                required
            />
        </div>
        
        <button type="submit">Create Organization</button>
    </form>
</main>

<%- include('partials/footer') %>