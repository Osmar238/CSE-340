<%- include('partials/header') %>
    <main>
        <h1><%= title %></h1>
        <h2>Organized by: <%= project.organization_name %></h2>
        
        <p><strong>Description:</strong> <%= project.description %></p>
        <p><strong>Location:</strong> <%= project.location %></p>
        <p><strong>Date:</strong> <%= new Date(project.date).toLocaleDateString() %></p>

        <h3>Categories:</h3>
        <% if (categories && categories.length > 0) { %>
            <ul>
                <% categories.forEach(category => { %>
                    <li>
                        <a href="/category/<%= category.category_id %>"><%= category.name %></a>
                    </li>
                <% }) %>
            </ul>
        <% } else { %>
            <p>No categories assigned.</p>
        <% } %>

        <p><a href="/assign-categories/<%= project.project_id %>">Edit Categories</a></p>
        <p><a href="/edit-project/<%= project.project_id %>" class="button">Edit Project</a></p>
    </main>
<%- include('partials/footer') %>